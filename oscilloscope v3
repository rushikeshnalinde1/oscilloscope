#include<LovyanGFX.hpp>
class LGFX : public lgfx::LGFX_Device{
  lgfx::Panel_ILI9341 _panel;
  lgfx::Bus_Parallel8 _bus;

  public:
    LGFX(void){
      auto cfg = _bus.config();
      cfg.freq_write = 20000000;
      cfg.pin_wr = 4;
      cfg.pin_rd = 2;
      cfg.pin_rs = 15;
      cfg.pin_d0 = 12;
      cfg.pin_d1 = 13;
      cfg.pin_d2 = 26;
      cfg.pin_d3 = 25;
      cfg.pin_d4 = 17;
      cfg.pin_d5 = 16;
      cfg.pin_d6 = 27;
      cfg.pin_d7 = 14;

      _bus.config(cfg);
      _panel.setBus(&_bus);

      auto pcfg = _panel.config();

      pcfg.pin_cs = 33;
      pcfg.pin_rst = 32;

      pcfg.memory_height = 320;
      pcfg.memory_width = 240;

      pcfg.panel_height = 320;
      pcfg.panel_width = 240;

      _panel.config(pcfg);
      setPanel(&_panel);

    }
};

LGFX tft;

const int inputPin = 34;

hw_timer_t *timerToggle = NULL;
hw_timer_t *timerSample = NULL;

volatile uint16_t buffer[25];

volatile int counter=0;

volatile bool fullFlag = false;

void IRAM_ATTR sample(){

  if(fullFlag) return;
  
  buffer[counter] = analogRead(inputPin);
  counter++;

  if(counter >= 25)
  {
    counter = 0;
    fullFlag = true;
  }
}


void setup(){
  pinMode(21, INPUT);
  tft.init();
  tft.setRotation(1);
  tft.fillScreen(TFT_BLACK);
  Serial.begin(115200);
  pinMode(inputPin, INPUT);
  timerSample = timerBegin(1000000);
  timerAttachInterrupt(timerSample, &sample);
  timerAlarm(timerSample, 500, true, 0);

  tft.fillRect(251, 0, 69, 240, TFT_BLACK); 
  tft.fillRect(252, 1, 68, 58, TFT_WHITE);
  tft.fillRect(252, 60, 68, 58, TFT_WHITE);
  tft.fillRect(252, 119, 68, 58, TFT_WHITE);
  tft.fillRect(252, 178, 68, 58, TFT_WHITE); 


  tft.setTextColor(TFT_BLACK);
  tft.setTextSize(2);
  tft.drawString("CH1 ", 255, 40);
  tft.drawString("Amp ", 255, 99);
  tft.drawString("Freq ", 255, 158);
  tft.drawString("Scale", 255, 217);
}

void loop(){

  static unsigned long lastUpdate = 0;
  

  if(fullFlag){

    int pause = digitalRead(21);
    if(pause) return;

    if(millis() - lastUpdate > 100){

      lastUpdate = millis();

      noInterrupts();

      uint16_t localBuffer[25];

      for(int i = 0; i < 25; i++){
        localBuffer[i] = buffer[i];
      }

      fullFlag = false;

      interrupts();

      // DRAWING CODE HERE
      tft.fillRect(0,0,250,236,TFT_WHITE);
      for(int x = 0; x < 249; x += 4){
        tft.drawPixel(x, 20, TFT_BLUE);
        tft.drawPixel(x, 70, TFT_BLUE);
        tft.drawPixel(x, 120, TFT_BLUE);
        tft.drawPixel(x, 170, TFT_BLUE);
        tft.drawPixel(x, 220, TFT_BLUE);
      }

      for(int y = 20; y < 220; y += 4){
        tft.drawPixel(0, y, TFT_BLUE);
        tft.drawPixel(50, y, TFT_BLUE);
        tft.drawPixel(100, y, TFT_BLUE);
        tft.drawPixel(150, y, TFT_BLUE);
        tft.drawPixel(200, y, TFT_BLUE);
        tft.drawPixel(250, y, TFT_BLUE);
      }


      int prevX = 0;
      int prevY = map(localBuffer[0], 0, 4095, 220, 20);

      for(int i = 1; i < 25; i++){

        int x = i * 10;
        int y = map(localBuffer[i], 0, 4095, 220, 20);

        tft.drawLine(prevX, prevY, x, y, TFT_RED);

        prevX = x;
        prevY = y;
      }
    }
  }
}
